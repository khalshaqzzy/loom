{
  "name": "@loom/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "prepare:shared": "npm --prefix ../../packages/contracts run build && npm --prefix ../../packages/decision-tree run build",
    "prestart": "npm run prepare:shared",
    "start": "expo start",
    "preandroid": "npm run prepare:shared",
    "android": "expo run:android",
    "preios": "npm run prepare:shared",
    "ios": "expo run:ios",
    "preweb": "npm run prepare:shared",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@config-plugins/react-native-ble-plx": "^7.0.0",
    "@expo/vector-icons": "^15.1.1",
    "@loom/contracts": "file:../../packages/contracts",
    "@loom/decision-tree": "file:../../packages/decision-tree",
    "@react-native-async-storage/async-storage": "2.2.0",
    "buffer": "^6.0.3",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
